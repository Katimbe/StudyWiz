# Kopala Media — environment variables template
# Copy to .env (local) or configure in your hosting provider (production).
# NEVER commit a real .env file.

# ---- Email delivery (activates live confirmation + notification emails) ----
# Serverless endpoint that accepts POST { to, subject, html, text, kind } and
# sends via your provider (Resend / SendGrid / Gmail API). See docs/integrations/email.md
VITE_EMAIL_ENDPOINT=

# ---- Lead storage backend (optional upgrade from browser storage) ----
# Endpoint implementing the lead repository contract. See docs/architecture/lead-storage.md
VITE_LEADS_ENDPOINT=

# ---- Analytics ----
# Google Tag Manager container ID (events already push to window.dataLayer)
VITE_GTM_ID=

# ---- Secrets below belong ONLY on the serverless backend, never in this app ----
# RESEND_API_KEY=
# HUBSPOT_PRIVATE_APP_TOKEN=
# SUPABASE_SERVICE_ROLE_KEY=
# TWILIO_ACCOUNT_SID= / TWILIO_AUTH_TOKEN=
